# 환경 변수 예시

# 데이터베이스
DATABASE_URL=postgresql://ai_detector:password@localhost:5432/ai_detector

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM 프로바이더 설정 (gemini | claude, 기본값: gemini)
LLM_PROVIDER=gemini

# Gemini API (무료 발급: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
# Gemini 모델 선택 (기본값: gemini-2.5-flash-lite)
GEMINI_MODEL=gemini-2.5-flash-lite

# Claude API (LLM_PROVIDER=claude 시 필요)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# API 설정
API_KEY=your-api-key-here
ENV=development

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
