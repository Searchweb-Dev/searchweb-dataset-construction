# 환경 변수 예시

# 데이터베이스
POSTGRES_PASSWORD=your-postgres-password-here
DATABASE_URL=postgresql://ai_detector:your-postgres-password-here@localhost:5432/ai_detector

# Redis
REDIS_URL=redis://localhost:6379/0

# 분류기 모드: llm (기본) | rule
CLASSIFIER_MODE=llm

# LLM 프로바이더 설정 (gemini | claude, 기본값: gemini)
LLM_PROVIDER=gemini

# Gemini API (무료 발급: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
# Gemini 모델 선택 (기본값: gemini-3.1-flash-lite)
GEMINI_MODEL=gemini-3.1-flash-lite

# Claude API (LLM_PROVIDER=claude 시 필요)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# API 설정
API_KEY=your-api-key-here
ENV=development

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 로그 레벨 (DEBUG | INFO | WARNING | ERROR, 기본값: INFO)
LOG_LEVEL=INFO

# 배치 분석 병렬 동시 실행 수 (LLM API rate limit 고려, 기본값: 5)
BATCH_CONCURRENCY=5
